    --section-horizontal-padding: {{section.settings.section_horizontal_padding }}px;
    {% comment %} Section Mobile Design {% endcomment %}
    --section-top-margin-mobile: {{ section.settings.section_top_margin_mobile }}px;
    --section-bottom-margin-mobile: {{ section.settings.section_bottom_margin_mobile }}px;
    --section-top-padding-mobile: {{ section.settings.section_top_padding_mobile }}px;
    --section-bottom-padding-mobile: {{ section.settings.section_bottom_padding_mobile }}px;
    --section-horizontal-padding-mobile: {{ section.settings.section_horizontal_padding_mobile }}px;
    {% comment %} Section Title Desktop Design {% endcomment %}
    --section-title-color: {{ section.settings.section_title_color }};
    --section-title-top-margin: {{section.settings.section_title_margin_top }}px;
    --section-title-bottom-margin: {{section.settings.section_title_margin_bottom }}px;
    --section-title-font-size: {{section.settings.section_title_font_size }}px;
    --section-title-line-height: {{section.settings.section_title_line_height }}px;
    --section-title-letter-spacing: {{section.settings.section_title_letter_spacing }}px;
    {% comment %} Section Title Mobile Design {% endcomment %}
    --section-title-top-margin-mobile: {{section.settings.section_title_margin_top_mobile }}px;
    --section-title-bottom-margin-mobile: {{section.settings.section_title_margin_bottom_mobile }}px;
    --section-title-font-size-mobile: {{section.settings.section_title_font_size_mobile }}px;
    --section-title-line-height-mobile: {{section.settings.section_title_line_height_mobile }}px;
    --section-title-letter-spacing-mobile: {{section.settings.section_title_letter_spacing_mobile }}px;
    {% comment %} Section Textarea Desktop Design {% endcomment %}
    --section-textarea-color: {{section.settings.section_textblock_color }};
    --section-textarea-top-margin: {{section.settings.section_textarea_margin_top }}px;
    --section-textarea-bottom-margin: {{section.settings.section_textarea_margin_bottom }}px;
    --section-textarea-font-size: {{section.settings.section_textarea_font_size }}px;
    --section-textarea-line-height: {{section.settings.section_textarea_line_height }}px;
    --section-textarea-letter-spacing: {{section.settings.section_textarea_letter_spacing }}px;
    {% comment %} Section Textarea Mobile Design {% endcomment %}
    --section-textarea-top-margin-mobile: {{section.settings.section_textarea_margin_top_mobile }}px;
    --section-textarea-bottom-margin-mobile: {{section.settings.section_textarea_margin_bottom_mobile }}px;
    --section-textarea-font-size-mobile: {{section.settings.section_textarea_font_size_mobile }}px;
    --section-textarea-line-height-mobile: {{section.settings.section_textarea_line_height_mobile }}px;
    --section-textarea-letter-spacing-mobile: {{section.settings.section_textarea_letter_spacing_mobile}}px;

    --image-marker-color : {{section.settings.marker_color }};
    --image-marker-active-color : {{ section.settings.marker_color_active }};

    --product-content-backgroud-color: {{ section.settings.product_content_background_color }};
    --product-content-border-radius: {{ section.settings.product_content_border_radius}}px;
    --product-image-container-alignment: {{ section.settings.product_image_container }};
    --product-image-content-gap: {{ section.settings.product_image_gap}}px;
    --product-content-vertical-padding: {{section.settings.product_content_vertical_padding }}px;
    --product-content-horizontal-padding: {{section.settings.product_content_horizontal_padding }}px;
    --product-image-content-gap-mobile: {{ section.settings.product_image_gap_mobile}}px;
    --product-content-vertical-padding-mobile: {{section.settings.product_content_vertical_padding_mobile}}px;
    --product-content-horizontal-padding-mobile: {{section.settings.product_content_horizontal_padding_mobile }}px;
    --product-image-width: {{ section.settings.product_image_width }}rem;
    --product-image-radius: {{ section.settings.product_image_radius }}px;
    --product-image-border-color: {{ section.settings.product_image_border_color }};
    --product-image-border-width: {{section.settings.product_image_border_width }}px;

    --product-image-width-mobile: {{ section.settings.product_image_width_mobile }}rem;
    --product-image-radius-mobile: {{ section.settings.product_image_radius_mobile }}px;
    {% comment %} Product Title Styling {% endcomment %}
    --product-title-color: {{ section.settings.product_title_color }};
    --product-title-margin-top : {{section.settings.product_title_margin_top }}px;
    --product-title-margin-bottom : {{section.settings.product_title_margin_bottom }}px;
    --product-title-font-size : {{section.settings.product_title_font_size }}px;
    --product-title-line-height: {{section.settings.product_title_line_height }}px;
    --product-title-letter-spacing: {{section.settings.product_title_letter_spacing }}px;
    {% comment %} Product Title Styling - Mobile {% endcomment %}
     --product-title-margin-top-mobile : {{section.settings.product_title_margin_top_mobile }}px;
    --product-title-margin-bottom-mobile : {{section.settings.product_title_margin_bottom_mobile }}px;
    --product-title-font-size-mobile : {{section.settings.product_title_font_size_mobile }}px;
    --product-title-line-height-mobile: {{section.settings.product_title_line_height_mobile }}px;
    --product-title-letter-spacing-mobile: {{section.settings.product_title_letter_spacing_mobile }}px;
    {% comment %} Product Price Styling {% endcomment %}
    --product-price-color: {{section.settings.product_price_color }};
    --product-price-top-margin: {{ section.settings.product_price_margin_top }}px;
    --product-price-bottom-margin: {{ section.settings.product_price_margin_bottom }}px;
    --product-price-font-size: {{ section.settings.product_price_font_size }}px;
    --product-price-letter-spacing-size: {{section.settings.product_price_letter_spacing_size }}px;
    {% comment %} Product Price Styling - Mobile {% endcomment %}
    --product-price-top-margin-mobile: {{ section.settings.product_price_margin_top_mobile }}px;
    --product-price-bottom-margin-mobile: {{ section.settings.product_price_margin_bottom_mobile }}px;
    --product-price-font-size-mobile: {{ section.settings.product_price_font_size_mobile}}px;
    --product-price-letter-spacing-size-mobile: {{section.settings.product_price_letter_spacing_mobile }}px;
    {% comment %} Product Button Styling  {% endcomment %}
    --product-button-horizontal-padding:{{ section.settings.button_horizontal_padding }}px;
    --product-button-vertical-padding:{{ section.settings.button_vertical_padding }}px;
    --product-button-border-width:{{ section.settings.button_border_width }}px;
    --product-button-border-radius:{{ section.settings.button_border_radius }}px;
    --product-button-margin-top:{{ section.settings.button_margin_top }}px;
    --product-button-margin-bottom:{{ section.settings.button_margin_bottom }}px;
    --product-button-font-size: {{section.settings.button_font_size }}px;
    --product-button-letter-spacing: {{section.settings.button_letter_spacing }}px;
    --product-button-color: {{ section.settings.button_color }};
    --product-button-background-color: {{ section.settings.button_background_color }};
    --product-button-border-color: {{ section.settings.button_border_color }};
    --product-button-hover-color: {{section.settings.button_hover_color }};
    --product-button-hover-background-color: {{ section.settings.button_hover_background_color }};
    --product-button-hover-border-color: {{section.settings.button_hover_border_color }};

     {% comment %} Product Button Styling - Mobile {% endcomment %}
    --product-button-margin-top-mobile:{{ section.settings.button_margin_top_mobile }}px;
    --product-button-margin-bottom-mobile:{{ section.settings.button_margin_bottom_mobile }}px;
    --product-button-font-size-mobile: {{section.settings.button_font_size_mobile }}px;
    --product-button-letter-spacing-mobile: {{section.settings.button_letter_spacing_mobile }}px;

  }
</style>
<div {{ section.shopify_attributes }}>
  <div class="outer-container">
    <div class="inner-container">
      <div
        class="section_title__wrapper"
        style="text-align: {{ section.settings.section_title_alignment }}"
      >
        <{{ section.settings.html_element }}
          class="section_title__class"
          style="
            font-family: {% if section.settings.use_custom_font == true and section.settings.section_title_custom_font_family != '' %}
            {{ section.settings.section_title_custom_font_family }}
            {% else %}
            {{ section.settings.section_title_font.family }}
            {% endif %};
                font-weight: {% if section.settings.section_title_font_weight == 'light'%}
                    300
                {% elsif section.settings.section_title_font_weight == 'regular' %}
                    400
                    {% elsif section.settings.section_title_font_weight == 'semi_bold' %}
                    600
                {% elsif section.settings.section_title_font_weight == 'bold' %}
                    700
                {% else %}
                    normal
                {% endif %};
          "
        >
          {{- section.settings.section_title -}}
        </{{ section.settings.html_element }}>
        <div
          class="section_text__class"
          style="
            font-family: {% if section.settings.use_custom_font_2 == true and section.settings.custom_fontfamily_name != '' %}
            {{ section.settings.custom_fontfamily_name }}
             {% else %}
             {{ section.settings.textarea_font.family }}
            {% endif %};
             font-weight: {% if section.settings.textarea__font_weight == 'light'%}
                    300
                {% elsif section.settings.textarea__font_weight == 'regular' %}
                    400
                    {% elsif section.settings.textarea__font_weight == 'semi_bold' %}
                    600
                {% elsif section.settings.textarea__font_weight == 'bold' %}
                    700
                    {%else %}
                    normal
                {% endif %};
          "
        >
          {{ section.settings.section_richtext_title }}
        </div>
      </div>
      <div class="image_section_wrapper">
        <div
          class="image_picker__class_outer_container"
          style="
            {% if section.settings.image_position == 'left' %}
            justify-content: left;
            {% elsif section.settings.image_position == 'center' %}
            justify-content: center;
            {% elsif section.settings.image_position == 'right'%}
            justify-content: right;
            {% endif %}
          "
        >
          <div
            class="image_picker__class"
            style="
                          aspect-ratio:{% if section.settings.image_dimension == 'landscape' %}
               16/9
              {% elsif section.settings.image_dimension == 'square' %}
               1/1
              {% elsif section.settings.image_dimension == 'portrait' %}
               2/3
               {% else %}
                2/3
               {% endif %};
                border-radius: {{ section.settings.image_border  }}px;
            "
          >
            {% if section.settings.image_picker_desktop %}
              <div class="section_image_parent">
                {{ section.settings.image_picker_desktop | image_url: width: 1500, height: 1500 | image_tag }}
              </div>
            {% endif %}

            {% for block in section.blocks %}
              {% if block.type == 'product' %}
                <button
                  class="dot__button"
                  style="
                     padding: {% if section.settings.marker_size == 'small' %}
                        5px 5px
                       {% elsif section.settings.marker_size == 'medium' %}
                        7px 7px
                        {% elsif section.settings.marker_size == 'large' %}
                         10px 10px
                       {% endif %};
                    left: {{ block.settings.horizontal_position }}%;
                    top: {{ block.settings.vertical_position }}%;
                  "
                  data-product-id="{{ block.settings.product.id }}"
                ></button>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        <div class="product_section__outer_wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'product' and block.settings.product != blank %}
              {% assign has_products = true %}
              <div
                class="product_section__inner_wrapper card"
                data-product-id="{{ block.settings.product.id }}"
                {% if forloop.first %}
                  style="display: flex"
                {% else %}
                  style="display:none"
                {% endif %}
              >
                <div
                  class="product_image_wrapper"
                  style="
                                       {% if section.settings.show_product_image == true %}
                    display: block;
                    {% else %}
                    display: none;
                    {% endif %}
                  "
                >
                  {{
                    block.settings.product.featured_image
                    | image_url: width: 500, height: 500
                    | image_tag: class: 'product__image'
                  }}
                </div>
                <div {{ block.shopify_attributes }} class="product_text_content__wrapper" style="text-align: center">
                  <{{ section.settings.product_title_html }}
                    class="product_title_wrapper"
                    style="
                      {% if section.settings.show_product_title_checkbox == true %}
                        display: block;
                            {% if section.settings.product_title_custom_font == true %}
                                font-family: {{section.settings.product_title_custom_font_family_name }}
                            {% else %}
                                font-family: {{ section.settings.product_title_font_picker.family }}
                            {%endif %};
                                font-weight: {% if section.settings.product_title_font_weight == 'default' %}
                                normal;
                            {% else %}
                                {{ section.settings.product_title_font_weight }}
                            {% endif %};
                            {%else %}
                                display: none;
                      {% endif %}
                    "
                  >
                    {{ block.settings.product.title }}
                  </{{ section.settings.product_title_html }}>
                  <div
                    class="product_price_wrapper"
                    style="
                                       display: {% if section.settings.show_product_price == true %}block{% else %}none{% endif %};
                      {% if section.settings.show_product_price == true %}
                        font-family: {% if section.settings.product_price_custom_font == true %}
                          {{ section.settings.product_price_font_family }}
                        {% else %}
                          {{ section.settings.product_price_title_font.family }}
                        {% endif %};
                        font-weight: {% if section.settings.product_price_font_weight == 'default' %}
                          normal
                        {% else %}
                          {{ section.settings.product_price_font_weight }}
                        {% endif %};
                      {% endif %}
                    "
                  >
                    {{ block.settings.product.price | money }}
                  </div>
                </div>
                <button
                  class="product_button_wrapper"
                  style="
                    display: {% if section.settings.button_checkbox == true %}block{% else %}none{% endif %};
                    font-family: {% if section.settings.button_custom_font == true and section.settings.button_custom_font_family != '' %}
                      {{ section.settings.button_custom_font_family }}
                    {% else %}
                      {{ section.settings.button_font_picker.family }}
                    {% endif %};
                    font-weight: {% if section.settings.button_font_weight == 'default' %}
                      normal
                    {% else %}
                      {{ section.settings.button_font_weight }}
                    {% endif %};
                  "
                >
                  <div>
                    <a class="product_button_anchor_link">{{ section.settings.button_label }}</a>
                  </div>
                </button>
              </div>
            {% endif %}
          {% endfor %}
          {% unless has_products %}
            <p>No Product Selected.</p>
          {% endunless %}
        </div>
      </div>
    </div>
  </div>
</div>
<script src="{{ 'shop-the-look.js' | asset_url }}" async></script>

{% schema %}
{
  "name": "Shop The Look",
  "class": "shop_the_look",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "label": "Section Title (Optional)",
      "id": "section_title"
    },
    {
      "type": "select",
      "label": "HTML Element",
      "id": "html_element",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2",
      "info": "For better SEO"
    },
    {
      "type": "richtext",
      "label": "Section Text",
      "id": "section_richtext_title"
    },
    {
      "type": "header",
      "content": "IMAGE"
    },
    {
      "type": "image_picker",
      "label": "Image",
      "id": "image_picker_desktop"
    },
    {
      "type": "image_picker",
      "id": "image_picker_modile",
      "label": "Image for Mobile"
    },
    {
      "type": "select",
      "label": "Image Dimension",
      "id": "image_dimension",
      "options": [
        {
          "value": "original",
          "label": "Original"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "original"
    },
    {
      "type": "select",
      "label": "Image Position",
      "id": "image_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "IMAGE STYLING"
    },
    {
      "type": "range",
      "id": "image_border",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Image Border Radius",
