      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section Bottom Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_horizontal_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section Horizontal Padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "SECTION STYLING - MOBILE"
    },
    {
      "type": "range",
      "id": "section_top_margin_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section Top Margin - Mobile",
      "default": 0
