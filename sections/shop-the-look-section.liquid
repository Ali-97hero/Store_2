    {
      "type": "header",
      "content": "SECTION TITLE STYLING - MOBILE"
    },
    {
      "type": "range",
      "id": "section_title_margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section Title Top Margin - Mobile",
